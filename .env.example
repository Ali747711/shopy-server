# ─────────────────────────────────────────────────────────────
# Shopy Backend — environment template (safe to commit)
# Copy to .env and fill in real values. Generate JWT secrets with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── MongoDB (Atlas) ──
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.xxxxx.mongodb.net/shopy?retryWrites=true&w=majority
MONGODB_DB_NAME=shopy

# ── Redis ──
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ── Auth / JWT ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=12

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── AI cost guardrail ──
AI_DAILY_BUDGET_USD=5

# ── Rate limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
